<beans xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="beans.xsd">

	<bean class="de.hybris.platform.commercefacades.product.data.ProductData">
		<property name="genders" type="java.util.List&lt;br.com.telefonica.facades.product.data.GenderData>"/>
	</bean>

	<bean class="br.com.telefonica.facades.product.data.GenderData">
		<property name="code" type="String"/>
		<property name="name" type="String"/>
	</bean>

    <bean class="de.hybris.platform.commercefacades.product.data.ReviewData">
        <property name="verifiedPurchase" type="Boolean"/>
        <property name="approvalStatus" type= "String"/>
        <property name="reviewPk" type= "String"/>
        <property name="usefulCount"      type="Integer"/>
    </bean>

    <bean class="de.hybris.platform.commercewebservicescommons.dto.product.ReviewWsDTO">
        <property name="verifiedPurchase" type="Boolean"/>
        <property name="approvalStatus"   type="String"/>
        <property name="usefulCount"      type="Integer"/>
        <property name="reviewPk"         type="Long"/>
    </bean>

    <bean class="br.com.telefonica.facades.review.data.ReviewVoteData">
        <property name="voted"      type="Boolean"/>
        <property name="reviewPk"   type="String"/>
        <property name="totalVotes" type="Integer"/>
    </bean>

    <bean class="br.com.telefonica.occ.review.ReviewVoteWsDTO">
        <property name="voted"      type="Boolean"/>
        <property name="reviewPk"   type="String"/>
        <property name="totalVotes" type="Integer"/>
    </bean>

</beans>
