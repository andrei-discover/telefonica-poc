<config xmlns="http://www.hybris.com/cockpit/config"
	xmlns:na="http://www.hybris.com/cockpitng/config/notifications"
		xmlns:y="http://www.hybris.com/cockpit/config/hybris">

    <context merge-by="module" component="editorareaactions" type="Consignment">
        <y:actions xmlns:y="http://www.hybris.com/cockpit/config/hybris">
            <y:group qualifier="common">
                <y:label>actiongroup.common</y:label>
                <y:action action-id="br.com.telefonica.backoffice.actions.confirmpickupaction"
                          property="currentObject"/>
            </y:group>
        </y:actions>
    </context>

	<!-- Notification Area-->
	<context component="notification-area">
		<na:notification-area>
			<na:notifications eventType="telefonicabackoffice.confirmpickup.event" level="SUCCESS">
				<na:message>hmc.action.confirmpickup.success</na:message>
			</na:notifications>
		</na:notification-area>
	</context>

	<context component="explorer-tree" parent="auto" merge-by="module" >
		<explorer-tree:explorer-tree
				xmlns:explorer-tree="http://www.hybris.com/cockpitng/config/explorertree">
			<explorer-tree:navigation-node id="telefonica" >
				<explorer-tree:type-node id="productQuestions"
										 code="ProductQuestion"/>
                <explorer-tree:type-node id="customerReview"
                                         code="CustomerReview"/>
                <explorer-tree:type-node id="customerReviewVote"
                                         code="CustomerReviewVote"/>
			</explorer-tree:navigation-node>
		</explorer-tree:explorer-tree>
	</context>

	<context type="ProductQuestion" component="listview" merge-by="type" parent="GenericItem">
		<list-view:list-view
				xmlns:list-view="http://www.hybris.com/cockpitng/component/listView">
			<list-view:column qualifier="question" />
			<list-view:column qualifier="product" />
			<list-view:column qualifier="customer" />
			<list-view:column qualifier="status" />
			<list-view:column qualifier="creationtime" />
		</list-view:list-view>
	</context>

	<context type="ProductQuestion" component="advanced-search" merge-by="type" parent="GenericItem">
		<advanced-search:advanced-search
				xmlns:advanced-search="http://www.hybris.com/cockpitng/config/advancedsearch">
			<advanced-search:field-list>
				<advanced-search:field name="status"/>
				<advanced-search:field name="product"/>
				<advanced-search:field name="customer"/>
			</advanced-search:field-list>
		</advanced-search:advanced-search>
	</context>

	<context type="ProductQuestion" component="base">
		<base:base xmlns:base="http://www.hybris.com/cockpitng/config/base">
			<base:type code="ProductQuestion"/>
		</base:base>
	</context>

    <context merge-by="type" parent="GenericItem" type="CustomerReview" component="editor-area">
        <editorArea:editorArea xmlns:editorArea="http://www.hybris.com/cockpitng/component/editorArea">
            <editorArea:tab name="tab.customerreview.essencial">
                <editorArea:section name="section.customerreview.essencial">
                    <editorArea:attribute qualifier="product"/>
                    <editorArea:attribute qualifier="user"/>
                    <editorArea:attribute qualifier="rating"/>
                    <editorArea:attribute qualifier="headline"/>
                    <editorArea:attribute qualifier="comment"/>
                    <editorArea:attribute qualifier="blocked"/>
                    <editorArea:attribute qualifier="approvalStatus"/>
                    <editorArea:attribute qualifier="language"/>
                </editorArea:section>
            </editorArea:tab>

            <editorArea:tab name="tab.customerreview.telefonica">
                <editorArea:section name="section.customerreview.telefonica">
                    <editorArea:attribute qualifier="verifiedPurchase"/>
                    <editorArea:attribute qualifier="usefulCount"/>
                    <editorArea:attribute qualifier="moderationNotes"/>
                </editorArea:section>
            </editorArea:tab>

            <editorArea:tab name="tab.customerreview.metadata">
                <editorArea:section name="section.customerreview.metadata">
                    <editorArea:attribute qualifier="pk"/>
                    <editorArea:attribute qualifier="creationtime"/>
                    <editorArea:attribute qualifier="modifiedtime"/>
                    <editorArea:attribute qualifier="owner"/>
                </editorArea:section>
            </editorArea:tab>
        </editorArea:editorArea>
    </context>

    <context type="CustomerReview" component="advanced-search" merge-by="type" parent="GenericItem">
        <advanced-search:advanced-search
                xmlns:advanced-search="http://www.hybris.com/cockpitng/config/advancedsearch">

            <advanced-search:field-list>
                <advanced-search:field name="product"/>
                <advanced-search:field name="user"/>
            </advanced-search:field-list>
        </advanced-search:advanced-search>
    </context>

    <context type="CustomerReview" component="base">
        <base:base xmlns:base="http://www.hybris.com/cockpitng/config/base">
            <base:type code="CustomerReview"/>
        </base:base>
    </context>

    <context merge-by="type" parent="GenericItem" type="CustomerReviewVote" component="editor-area">
        <editorArea:editorArea xmlns:editorArea="http://www.hybris.com/cockpitng/component/editorArea">
            <editorArea:tab name="tab.customerreviewvote.essencial">
                <editorArea:section name="section.customerreviewvote.essencial">
                    <editorArea:attribute qualifier="review"/>
                    <editorArea:attribute qualifier="voter"/>
                    <editorArea:attribute qualifier="votedAt"/>
                </editorArea:section>
            </editorArea:tab>

            <editorArea:tab name="tab.customerreviewvote.metadata">
                <editorArea:section name="section.customerreviewvote.metadata">
                    <editorArea:attribute qualifier="pk"/>
                    <editorArea:attribute qualifier="creationtime"/>
                    <editorArea:attribute qualifier="modifiedtime"/>
                    <editorArea:attribute qualifier="owner"/>
                </editorArea:section>
            </editorArea:tab>
        </editorArea:editorArea>
    </context>

    <context type="CustomerReviewVote" component="advanced-search" merge-by="type" parent="GenericItem">
        <advanced-search:advanced-search
                xmlns:advanced-search="http://www.hybris.com/cockpitng/config/advancedsearch">

            <advanced-search:field-list>
                <advanced-search:field name="voter"/>
                <advanced-search:field name="review"/>
            </advanced-search:field-list>
        </advanced-search:advanced-search>
    </context>
    <context type="CustomerReviewVote" component="base">
        <base:base xmlns:base="http://www.hybris.com/cockpitng/config/base">
            <base:type code="CustomerReviewVote"/>
        </base:base>
    </context>

	<context merge-by="type" parent="GenericItem" type="ProductQuestion" component="editor-area">
		<editorArea:editorArea xmlns:editorArea="http://www.hybris.com/cockpitng/component/editorArea">
			<editorArea:essentials>
				<editorArea:essentialSection name="section.productquestion.essential">
					<editorArea:attribute qualifier="product"/>
					<editorArea:attribute qualifier="customer"/>
					<editorArea:attribute qualifier="status"/>
					<editorArea:attribute qualifier="creationtime"/>
				</editorArea:essentialSection>
			</editorArea:essentials>
			<editorArea:tab name="tab.productquestion.qna">
				<editorArea:section name="section.productquestion.question" position="0">
					<editorArea:attribute qualifier="question"/>
					<editorArea:attribute qualifier="status"/>
					<editorArea:attribute qualifier="customer"/>
					<editorArea:attribute qualifier="product"/>
				</editorArea:section>

				<editorArea:section name="section.productquestion.answer" position="1">
					<editorArea:attribute qualifier="answer"/>
					<editorArea:attribute qualifier="answerModerator"/>
					<editorArea:attribute qualifier="answerModeratedAt"/>
					<editorArea:attribute qualifier="moderationNotes"/>
				</editorArea:section>
			</editorArea:tab>
		</editorArea:editorArea>
	</context>


	<context type="ProductQuestion" component="editorareaactions">
		<y:actions>
			<y:group qualifier="common" position="10">
				<y:label>actiongroup.common</y:label>
				<y:action action-id="br.com.telefonica.backoffice.actions.questionmoderationaction"
						  property="currentObject" position="10"/>
			</y:group>
		</y:actions>
	</context>

	<context type="CustomerReview" component="editorareaactions">
		<y:actions>
			<y:group qualifier="common" position="10">
				<y:label>actiongroup.common</y:label>
				<y:action action-id="br.com.telefonica.backoffice.actions.reviewmoderationaction" property="currentObject" position="10"/>
			</y:group>
		</y:actions>
	</context>

</config>
