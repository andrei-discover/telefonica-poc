<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<config xmlns="http://www.hybris.com/cockpit/config"
		xmlns:na="http://www.hybris.com/cockpitng/config/notifications">

	<context merge-by="module" component="editorareaactions" type="Consignment">
		<y:actions xmlns:y="http://www.hybris.com/cockpit/config/hybris">
			<y:group qualifier="common">
				<y:label>actiongroup.common</y:label>
				<y:action action-id="br.com.telefonica.backoffice.actions.confirmpickupaction"
						  property="currentObject"/>
			</y:group>
		</y:actions>
	</context>

	<context component="notification-area">
		<na:notification-area>
			<na:notifications eventType="telefonicabackoffice.confirmpickup.event" level="SUCCESS">
				<na:message>hmc.action.confirmpickup.success</na:message>
			</na:notifications>
		</na:notification-area>
	</context>

	<context component="explorer-tree" parent="auto" merge-by="module" >
		<explorer-tree:explorer-tree
				xmlns:explorer-tree="http://www.hybris.com/cockpitng/config/explorertree">
			<explorer-tree:navigation-node id="telefonica">
				<explorer-tree:type-node id="productQuestions"
										 code="ProductQuestion"/>
			</explorer-tree:navigation-node>
		</explorer-tree:explorer-tree>
	</context>

	<context type="ProductQuestion" component="listview" merge-by="type" parent="GenericItem">
		<list-view:list-view
				xmlns:list-view="http://www.hybris.com/cockpitng/component/listView">
			<list-view:column qualifier="question" label="Pergunta"/>
			<list-view:column qualifier="product" label="Produto"/>
			<list-view:column qualifier="customer" label="Cliente"/>
			<list-view:column qualifier="status" label="Status"/>
			<list-view:column qualifier="creationtime" label="Criado em"/>
		</list-view:list-view>
	</context>

	<context type="ProductQuestion" component="editor-area" merge-by="type" parent="GenericItem">
		<editorArea:editorArea
				xmlns:editorArea="http://www.hybris.com/cockpitng/component/editorArea">
			<editorArea:tab name="Geral">
				<editorArea:section name="Dados">
					<editorArea:attribute qualifier="question"/>
					<editorArea:attribute qualifier="answer"/>
					<editorArea:attribute qualifier="product"/>
					<editorArea:attribute qualifier="customer"/>
					<editorArea:attribute qualifier="status"/>
				</editorArea:section>
			</editorArea:tab>
		</editorArea:editorArea>
	</context>

	<context type="ProductQuestion" component="advanced-search" merge-by="type" parent="GenericItem">
		<advanced-search:advanced-search
				xmlns:advanced-search="http://www.hybris.com/cockpitng/config/advancedsearch">

			<advanced-search:field-list>
				<advanced-search:field name="status"/>
				<advanced-search:field name="product"/>
				<advanced-search:field name="customer"/>
			</advanced-search:field-list>
		</advanced-search:advanced-search>
	</context>

	<context type="ProductQuestion" component="base">
		<base:base xmlns:base="http://www.hybris.com/cockpitng/config/base">
			<base:type code="ProductQuestion"/>
		</base:base>
	</context>

</config>