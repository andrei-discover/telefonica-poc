                            ; testProduct:testCatalog:Online                                    ; test.customer@test.com  ; 4     ; Good product!          ; Very good product! ; approved            ; en               ; false
                            ; testProduct:testCatalog:Online                                    ; test.customer@test.com  ; 3     ; Average product!       ; Average product!   ; pending             ; en               ; false

