INSERT_UPDATE UserGroup; uid[unique = true]
                       ; testgroup

INSERT_UPDATE Customer; uid[unique = true]     ; name
                      ; test.customer@test.com ; Test Customer

INSERT_UPDATE Product; code[unique = true]; catalogVersion(catalog(id), version)
                     ; testProduct        ; testCatalog:Online

INSERT_UPDATE CustomerReview; product(code, catalogVersion(catalog(id), version))[unique = true]; user(uid)[unique = true]; rating; headline[unique = true]; comment            ; approvalStatus(code); language(isocode); verifiedPurchase
